signs = {
  \override Beam #'breakable = ##t
  \set Staff.instrumentName = #"signs"
  \set Staff.shortInstrumentName = #"signs"
  \clef "bass"
  % prelude
  s8 * 12 * 11
  \repeat unfold 11 {
    e8[^"tamara" c a c]
  }
  \repeat unfold 11 {
    f8[^"zirma" c b a]
  }
  \repeat unfold 11 {
    f8[^"zoe" c]
  }
  \repeat unfold 11 {
    d8[^"hypatia" a e d e]
  }
  \repeat unfold 11 {
    c8[^"olivia" a d]
  }
}
