desire = {
  \override Beam #'breakable = ##t
  \set Staff.instrumentName = #"desire"
  \set Staff.shortInstrumentName = #"des."
  \repeat unfold 11 {
    d8[^"dorothea" c f c b g b g]
  }
  \repeat unfold 11 {
    b8[^"anastasia" a g b a d]
  }
  \repeat unfold 11 {
    f8[^"despina" d f e g e]
  }
  \repeat unfold 11 {
    d8[^"fedora" b d f e g]
  }
  \repeat unfold 11 {
    a8[^"zobeide" f b g e a g]
  }
}
