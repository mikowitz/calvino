desire = {
  \set Staff.instrumentName = #"desire"
  \set Staff.shortInstrumentName = #"des."
  s8 * 12 * 10
  s8 * 12 * 10
  %% dorothea
  \repeat unfold 45 {
    d'8[ c' f' c' b' g' b' g']
  }
  %% anastasia
  \repeat unfold 20 {
    b'[ a' g' b' a' d'']
  }
  s8 * 12 * 10
  s8 * 3
  %% despina
  \repeat unfold 40 {
    f'8-> d' f' e' g' e'
  }
}
