thin = {
  \override Beam #'breakable = ##t
  \set Staff.instrumentName = #"thin"
  \set Staff.shortInstrumentName = #"thin"
  \repeat unfold 11 {
    d8[^"isaura" e c d c]
  }
  \repeat unfold 11 {
    c8[^"zenobia" f b e c b e]
  }
  \repeat unfold 11 {
    b8[^"armilla" c g a c]
  }
  \repeat unfold 11 {
    c8[^"sophronia" a d g e a d b]
  }
  \repeat unfold 11 {
    b8[^"octavia" c f c]
  }
}
