memory = {
  \override Beam #'breakable = ##t
  \set Staff.instrumentName = #"memory"
  \set Staff.shortInstrumentName = #"mem."
  \clef "bass"
  \time 12/8 
  % prelude
  s8 * 12 * 11
  % diomira
  \repeat unfold 11 {
    d8[^"diomira" g a g f a]
  }
  \repeat unfold 11 {
    f8[^"isidora" a b g]
  }
  \repeat unfold 11 {
    g8[^"zaira" e d]
  }
  \repeat unfold 11 {
    d8[^"zora" c e g]
  }
  \repeat unfold 11 {
    a8[^"maurilia" g e g a g]
  }
}
